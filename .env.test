# Set automatically by Next.js: development | test | production
NODE_ENV=test

# Display name of the application.
NEXT_PUBLIC_APP_NAME="Nextjs Boilerplate"

# Public base URL of this Next.js app.
# E2E: must match what `pnpm dev` serves (next dev --turbopack → http://localhost:3000).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend authority (host:port, no scheme). Single source for the URLs below.
BACKEND_HOST=localhost:3001

# REST client base URL
NEXT_PUBLIC_REST_URL="http://${BACKEND_HOST}"

# GraphQL HTTP endpoint
NEXT_PUBLIC_GRAPHQL_URL="http://${BACKEND_HOST}/graphql"

# GraphQL WebSocket endpoint (graphql-ws, subscriptions)
NEXT_PUBLIC_GRAPHQL_WS_URL="ws://${BACKEND_HOST}/graphql"

# Auth endpoint
NEXT_PUBLIC_AUTH_URL="http://${BACKEND_HOST}/api/auth"
