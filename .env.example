# Set automatically by Next.js: development | test | production
NODE_ENV=development

# Display name of the application.
NEXT_PUBLIC_APP_NAME="Nextjs Boilerplate"

# Public base URL of this Next.js app. Required: anchors metadataBase, the
# OG-image origin, canonical/hreflang links, robots.txt and the sitemap.
# Inlined at BUILD time (not read at runtime) — set it per environment build;
# don't promote one build artifact across envs. Use the real origin in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

################################
# Backend                      #
################################

# Backend authority (host:port, no scheme). Single source for every URL below;
# used only to compose them — not exported to the browser on its own.
BACKEND_HOST=localhost:3001

# REST client base URL
NEXT_PUBLIC_REST_URL="http://${BACKEND_HOST}"

# GraphQL HTTP endpoint
NEXT_PUBLIC_GRAPHQL_URL="http://${BACKEND_HOST}/graphql"

# GraphQL WebSocket endpoint (graphql-ws, subscriptions)
NEXT_PUBLIC_GRAPHQL_WS_URL="ws://${BACKEND_HOST}/graphql"

# Auth endpoint
NEXT_PUBLIC_AUTH_URL="http://${BACKEND_HOST}/api/auth"

################################
# REST API Codegen             #
################################

# Full URL of the OpenAPI spec served by the backend.
OPENAPI_URL="http://${BACKEND_HOST}/openapi.json"
