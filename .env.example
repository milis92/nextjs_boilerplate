# Base URL of the NestJS backend. Everything else is derived from this:
#   REST/Auth: $NEXT_PUBLIC_API_URL/api/auth
#   GraphQL:   $NEXT_PUBLIC_API_URL/graphql
#   Subs:      ws(s)://.../graphql
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public base URL of this Next.js app.
# Leave unset in local dev; set in production deployments.
# NEXT_PUBLIC_APP_URL=https://dash.example.com
